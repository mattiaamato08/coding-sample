print(f"Selected bigrams: {len(selected_bigrams):,}")
print(f"Saved selected bigrams to:\n{SELECTED_BIGRAMS_OUTPUT}")


def apply_bigrams_to_text(text, bigram_set):
    tokens = text.split()
    output_tokens = []

    i = 0

    while i < len(tokens):

        if i < len(tokens) - 1:
            candidate = tokens[i] + "_" + tokens[i + 1]

            if candidate in bigram_set:
                output_tokens.append(candidate)
                i += 2
                continue

        output_tokens.append(tokens[i])
        i += 1

    return " ".join(output_tokens)


print("Applying bigrams to corpus...")

df[BIGRAM_TEXT_COL] = df[TEXT_COL].apply(
    lambda x: apply_bigrams_to_text(x, selected_bigrams)
)

