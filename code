print("=" * 80)

# We use the min_df = 20 candidate list because it is the most inclusive.
# The final cutoff is not chosen mechanically from min_df alone. Instead,
# we inspect:
#
# 1. Local PMI rank curve:
#    This shows how quickly association strength declines across ranked bigrams.
#
# 2. Cumulative coverage:
#    This shows how much of all observed bigram occurrence mass is covered by
#    the top N selected bigrams.
#
# 3. Cutoff table:
#    This compares top 100, 250, 500, 1000, 2000, etc.
#
# The top-2000 cutoff is used because it is broad enough to retain many
# substantively meaningful political and institutional expressions, while
# still excluding the long tail of weaker and less interpretable bigrams.

bigram_path = BIGRAM_DIR / "bigram_pmi_min_df_20_full.csv"

bigrams_df = pd.read_csv(bigram_path)

if "local_pmi" not in bigrams_df.columns:
    raise ValueError("Column 'local_pmi' not found in bigram file.")

if "count" not in bigrams_df.columns:
    raise ValueError("Column 'count' not found in bigram file.")

bigrams_df = bigrams_df.sort_values("local_pmi", ascending=False).reset_index(drop=True)

bigrams_df["rank"] = bigrams_df.index + 1

print(f"Loaded bigrams: {len(bigrams_df):,}")

# Local PMI rank curve
plt.figure(figsize=(10, 6))
plt.plot(bigrams_df["rank"], bigrams_df["local_pmi"])
plt.yscale("log")
plt.xlabel("Bigram rank")
plt.ylabel("Local PMI, log scale")
