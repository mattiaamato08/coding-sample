# Function for random undersampling of the majority class
undersample <- function(data, target_col) {
  majority_class <- data %>% filter(get(target_col) == 2)
  minority_class <- data %>% filter(get(target_col) == 1)
  
  majority_sample <- majority_class %>% sample_n(nrow(minority_class))
  balanced_data <- bind_rows(majority_sample, minority_class) %>% sample_frac(1)
  return(balanced_data)
}

