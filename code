class_counts <- table(train_set$accident_severity)

# Define oversampling targets for each class
target_count_1 <- ifelse("1" %in% names(class_counts), class_counts["1"] * 5, 0)  
target_count_2 <- ifelse("2" %in% names(class_counts), class_counts["2"] + ceiling(class_counts["2"] * 1), 0) 

# Reduce class 3
target_count_3 <- ifelse("3" %in% names(class_counts), ceiling(class_counts["3"] * 0.6), 0)  

# Perform oversampling for minority classes and undersampling for the majority class
train_set_balanced <- train_set %>%
  group_by(accident_severity) %>%
  do({
    target_count <- switch(
      unique(.$accident_severity),
      `1` = target_count_1,
      `2` = target_count_2,
      `3` = target_count_3
    )
    
    # If the current number is below the target, apply oversampling
    if (nrow(.) < target_count) {
      bind_rows(., sample_n(., target_count - nrow(.), replace = TRUE))
      
      # If this is class 3 and it has more observations than the target, apply undersampling
    } else if (unique(.$accident_severity) == "3" && nrow(.) > target_count_3) {
      sample_n(., target_count_3)
      
    } else {
      # Keep the original rows if they are already sufficient
      .
    }
  }) %>%
  ungroup()

