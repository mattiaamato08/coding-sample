def normalize_text(x):
    if pd.isna(x):
        return ""
    x = str(x).lower()
    x = re.sub(r"\s+", " ", x)
    return x.strip()


def normalize_string(x):
    if pd.isna(x):
        return ""

    x = str(x).lower()
    x = unicodedata.normalize("NFKD", x)
    x = "".join(ch for ch in x if not unicodedata.combining(ch))
    x = re.sub(r"[^\w\s]", " ", x)
    x = re.sub(r"\s+", " ", x).strip()

    return x


def make_complex_key(df):
    key_cols = [
        c for c in [
            "link",
            "speaker",
            "date",
            "speechnumber",
            "period",
            "text"
        ]
        if c in df.columns
    ]

    return df[key_cols].fillna("").astype(str).agg("|||".join, axis=1)


