texts = df[TEXT_COL].tolist()
n_docs = len(texts)

print(f"Loaded documents: {n_docs:,}")

# ------------------------------------------------------------
# Methodological note:
#
# The goal is to identify meaningful two-word expressions such as
# "member_state", "european_union", "public_finance", etc.
#
# Simple frequency is not enough, because it favours generic word pairs.
# PMI is useful because it measures how strongly two words are associated
# relative to chance. However, plain PMI over-ranks rare combinations.
#
# Therefore, we use Local PMI:
#
#     Local PMI = PMI * bigram frequency
#
# This preserves the association logic of PMI but penalises extremely rare
# bigrams. Bigrams are therefore ranked by local_pmi and count.
#
# We run a grid over different min_df thresholds to inspect how sensitive the
# candidate bigram list is to minimum document frequency.
# ------------------------------------------------------------

print("Computing unigram counts...")

unigram_vectorizer = CountVectorizer(
    ngram_range=(1, 1),
    token_pattern=r"(?u)\b\w+\b"
)

X_uni = unigram_vectorizer.fit_transform(texts)

unigrams = unigram_vectorizer.get_feature_names_out()

unigram_counts = np.asarray(X_uni.sum(axis=0)).ravel()
total_unigrams = unigram_counts.sum()

unigram_count_dict = dict(zip(unigrams, unigram_counts))

print(f"Unique unigrams: {len(unigrams):,}")
print(f"Total unigram tokens: {total_unigrams:,}")

summary_rows = []

for min_df in MIN_DFS:

    print("=" * 70)
    print(f"Running bigram extraction with min_df={min_df}")
    print("=" * 70)

    bigram_vectorizer = CountVectorizer(
        ngram_range=(2, 2),
        min_df=min_df,
        token_pattern=r"(?u)\b\w+\b"
    )

    X_bi = bigram_vectorizer.fit_transform(texts)

    bigrams = bigram_vectorizer.get_feature_names_out()

    bigram_counts = np.asarray(X_bi.sum(axis=0)).ravel()
    bigram_docfreq = np.asarray((X_bi > 0).sum(axis=0)).ravel()

    total_bigrams = bigram_counts.sum()

    rows = []

    for bigram, count, docfreq in zip(bigrams, bigram_counts, bigram_docfreq):

        w1, w2 = bigram.split(" ", 1)

        c_w1 = unigram_count_dict.get(w1, 0)
        c_w2 = unigram_count_dict.get(w2, 0)

        if c_w1 == 0 or c_w2 == 0:
            continue

        p_bigram = count / total_bigrams
        p_w1 = c_w1 / total_unigrams
        p_w2 = c_w2 / total_unigrams

        pmi = np.log2(p_bigram / (p_w1 * p_w2))
        local_pmi = pmi * count

        rows.append({
            "bigram": bigram.replace(" ", "_"),
            "word1": w1,
            "word2": w2,
            "count": int(count),
            "document_frequency": int(docfreq),
            "share_documents": docfreq / n_docs,
            "pmi": pmi,
            "local_pmi": local_pmi
        })

    bigram_df = pd.DataFrame(rows)

    bigram_df = bigram_df.sort_values(
        ["local_pmi", "count"],
        ascending=[False, False]
    ).reset_index(drop=True)

    full_output_file = BIGRAM_DIR / f"bigram_pmi_min_df_{min_df}_full.csv"
    top_output_file = BIGRAM_DIR / f"bigram_pmi_min_df_{min_df}_top1000.csv"

    bigram_df.to_csv(
        full_output_file,
        index=False,
        encoding="utf-8-sig"
    )

    bigram_df.head(1000).to_csv(
        top_output_file,
        index=False,
        encoding="utf-8-sig"
    )

    summary_rows.append({
        "min_df": min_df,
        "n_unique_bigrams": len(bigram_df),
        "n_bigrams_count_ge_100": int((bigram_df["count"] >= 100).sum()),
        "n_bigrams_count_ge_500": int((bigram_df["count"] >= 500).sum()),
        "n_bigrams_count_ge_1000": int((bigram_df["count"] >= 1000).sum()),
        "top_bigram": bigram_df.iloc[0]["bigram"] if len(bigram_df) > 0 else None,
        "top_bigram_count": int(bigram_df.iloc[0]["count"]) if len(bigram_df) > 0 else 0,
        "top_bigram_pmi": float(bigram_df.iloc[0]["pmi"]) if len(bigram_df) > 0 else None,
        "full_output_file": str(full_output_file),
        "top_output_file": str(top_output_file)
    })

