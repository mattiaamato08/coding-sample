# Function to partially balance the dataset
partial_undersample <- function(data, target_col, imbalance_ratio = 1.5) {
  majority_class <- data %>% filter(get(target_col) == 2)
  minority_class <- data %>% filter(get(target_col) == 1)
  
  # Partial balancing: reduce the majority class to imbalance_ratio * minority class
  majority_sample <- majority_class %>%
    sample_n(floor(nrow(minority_class) * imbalance_ratio))
  
  # Combine and reshuffle
  balanced_data <- bind_rows(majority_sample, minority_class) %>%
    sample_frac(1)
  
  return(balanced_data)
}

